      "border.input": { "hex": "#ececec", "semantic": "border.input.default", "source": "Grey.100", "usage": "Form input borders" }
    },

    "border_semantic": {
      "_note": "These borders map to foundation tokens, not border.* paths",
      "foundation.assent (border)": { "hex": "#346bea", "semantic": "border.brand.default / border.input.focused", "source": "Blue.500", "usage": "Focus rings, active state borders, input focus" },
      "foundation.negative (border)": { "hex": "#dd1f11", "semantic": "border.danger.default / border.input.error", "source": "Red.700", "usage": "Error state borders on inputs" },
      "foundation.positive (border)": { "hex": "#429746", "semantic": "border.success.default", "source": "Green.500", "usage": "Success state borders" },
      "foundation.warning (border)": { "hex": "#ffca28", "semantic": "border.warning.default", "source": "Yellow.300", "usage": "Warning state borders" }
    },

    "icon": {
      "icon.primary": { "hex": "#8891a7", "semantic": "icon.neutral.default", "source": "BlueGrey.400", "usage": "Default icon color" },
      "icon.primaryHover": { "hex": "#52575e", "semantic": "icon.neutral.defaultHover", "source": "BlueGrey.600", "usage": "Default icon hover state" },
      "icon.secondary": { "hex": "#5d5d5d", "semantic": "icon.neutral.subtle", "source": "Grey.700", "usage": "Subdued icons, secondary actions" },
      "icon.accent": { "hex": "#346bea", "semantic": "icon.brand.default", "source": "Blue.500", "usage": "Brand/accent icons, active/selected state icons" },
      "icon.accentHover": { "hex": "#0260C9", "semantic": "icon.brand.hovered", "source": "System Blue (dark)", "usage": "Brand icon hover state" },
      "icon.critical": { "hex": "#dd1f11", "semantic": "icon.danger.default", "source": "Red.700", "usage": "Critical/error icons" },
      "icon.criticalHover": { "hex": "#a91b1b", "semantic": "icon.danger.hovered", "source": "Red.900", "usage": "Critical icon hover state" },
      "icon.actionIcon": { "hex": "#bababa", "semantic": "icon.action", "source": "Grey.400", "usage": "Action icons, toolbar icons" },
      "icon.draft": { "hex": "#c7c7c7", "semantic": "icon.draft", "source": "Grey.300", "usage": "Draft status icons" },
      "icon.active": { "hex": "#346bea", "semantic": "icon.active", "source": "Blue.500", "usage": "DEPRECATED — merged into icon.brand.default" },
      "icon.primaryNav": { "hex": "#6c7581", "semantic": "icon.primaryNav", "source": "BlueGrey.500", "usage": "Primary navigation icons" },
      "icon.black": { "hex": "#000000", "semantic": "icon.black", "source": "Black", "usage": "Pure black icons" },
      "icon.positive": { "hex": "#429746", "semantic": "icon.success.default", "source": "Green.500", "usage": "Success/positive icons" },
      "icon.warning": { "hex": "#ffca28", "semantic": "icon.warning.default", "source": "Yellow.300", "usage": "Warning icons" },
      "icon.informative": { "hex": "#0288D1", "semantic": "icon.information.default", "source": "System Blue", "usage": "Info icons" },
      "icon.disabled": { "hex": "#d0d8ea", "semantic": "icon.disabled", "source": "BlueGrey.200", "usage": "Disabled icons" },
      "icon.inversePrimary": { "hex": "#FFFFFF", "semantic": "icon.inverse", "source": "White", "usage": "Icons on dark/colored backgrounds" }
    }
  },

