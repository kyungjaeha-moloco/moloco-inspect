  "quickLookup": {
    "_note": "Flat lookup: given a hex value in light mode, find the correct token path",
    "#212121": "theme.mcui.palette.content.primary",
    "#5D5D5D": "theme.mcui.palette.content.secondary",
    "#346bea": "theme.mcui.palette.foundation.assent (also content.contentAccent, icon.accent, icon.active, border.beta)",
    "#dd1f11": "theme.mcui.palette.foundation.negative (also content.negative, icon.critical)",
    "#429746": "theme.mcui.palette.foundation.positive (also content.positive, icon.positive)",
    "#ffca28": "theme.mcui.palette.foundation.warning (also content.warning, icon.warning)",
    "#0288D1": "theme.mcui.palette.foundation.informative (also content.informative, icon.informative)",
    "#9E9E9E": "theme.mcui.palette.content.disabled",
    "#FFFFFF": "theme.mcui.palette.background.primary (also content.inversePrimary, icon.inversePrimary, background.input)",
    "#F8F8F8": "theme.mcui.palette.background.secondary",
    "#f8f9fd": "theme.mcui.palette.background.tertiary",
    "#EEEEEE": "theme.mcui.palette.background.primaryHover",
    "#E0E0E0": "theme.mcui.palette.background.primaryPressed (also border.disabled)",
    "#ffeae9": "theme.mcui.palette.background.negative",
    "#E8F5E9": "theme.mcui.palette.background.positive",
    "#ffebad": "theme.mcui.palette.background.warning",
    "#E1F5FE": "theme.mcui.palette.background.informative",
    "#E3F2FD": "theme.mcui.palette.background.selected",
    "#F5F5F5": "theme.mcui.palette.background.disabled (also background.inputDisabled)",
    "#ececec": "theme.mcui.palette.border.primary (also border.input, background.borderless)",
    "#ebf0fd": "theme.mcui.palette.border.secondary (also background.info)",
    "#8891a7": "theme.mcui.palette.icon.primary",
    "#5d5d5d": "theme.mcui.palette.icon.secondary",
    "#bababa": "theme.mcui.palette.content.grey (also icon.actionIcon)",
    "#6c7581": "theme.mcui.palette.content.blueGrey (also icon.primaryNav)",
    "#d0d8ea": "theme.mcui.palette.icon.disabled",
    "#0260C9": "theme.mcui.palette.foundation.assentHover (also content.contentAccentHover)",
    "#014599": "theme.mcui.palette.foundation.assentPressed (also content.contentAccentPressed)",
    "#c7c7c7": "theme.mcui.palette.icon.draft",
    "#ffdd74": "theme.mcui.palette.border.warning"
  }
