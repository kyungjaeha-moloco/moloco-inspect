{
  "$schema": "semantic-palette",
  "meta": {
    "description": "Direct mapping from theme.mcui.palette.* paths to hex values for both light and dark modes. Allows agents to verify color token selections without running the app.",
    "version": "1.0.0",
    "lastUpdated": "2026-04-06",
    "source": "Extracted from tokens.json color section and darkMode section"
  },

  "light": {
    "text": {
      "content.primary": { "hex": "#212121", "semantic": "text.neutral.default", "source": "Grey.900", "usage": "Default body text, headings, labels, data values" },
      "content.secondary": { "hex": "#5D5D5D", "semantic": "text.neutral.subtle", "source": "Grey.700", "usage": "Labels, hints, subdued text, form field labels" },
      "content.contentAccent": { "hex": "#346bea", "semantic": "text.brand.default", "source": "Blue.500", "usage": "Links, clickable text, brand actions" },
      "content.negative": { "hex": "#dd1f11", "semantic": "text.danger.default", "source": "Red.700", "usage": "Error messages, destructive action text" },
      "content.positive": { "hex": "#429746", "semantic": "text.success.default", "source": "Green.500", "usage": "Success messages, positive status text" },
      "content.warning": { "hex": "#ffca28", "semantic": "text.warning.default", "source": "Yellow.300", "usage": "Warning messages, caution text" },
      "content.informative": { "hex": "#0288D1", "semantic": "text.information.default", "source": "System Blue", "usage": "Informational messages, help text" },
      "content.disabled": { "hex": "#9E9E9E", "semantic": "text.disabled", "source": "Grey.500 approx", "usage": "Disabled text, placeholder text" },
      "content.inversePrimary": { "hex": "#FFFFFF", "semantic": "text.inverse", "source": "White", "usage": "Text on dark/colored backgrounds" },
      "content.grey": { "hex": "#bababa", "semantic": "text.neutral.grey", "source": "Grey.400", "usage": "Very subdued grey text" },
      "content.blueGrey": { "hex": "#6c7581", "semantic": "text.neutral.blueGrey", "source": "BlueGrey.500", "usage": "Blue-grey text for navigation and secondary UI" },
      "content.contentAccentHover": { "hex": "#0260C9", "semantic": ["text.brand.hovered", "text.link.hovered"], "source": "System Blue (dark)", "usage": "Brand/link text hover state" },
      "content.contentAccentPressed": { "hex": "#014599", "semantic": ["text.brand.pressed", "text.link.pressed"], "source": "System Blue (darker)", "usage": "Brand/link text pressed state" }
    },

    "background": {
      "background.primary": { "hex": "#FFFFFF", "semantic": "bg.neutral.default", "source": "White", "usage": "Main surface, panels, headers, popovers" },
      "background.secondary": { "hex": "#F8F8F8", "semantic": "bg.neutral.subtle", "source": "Grey.50", "usage": "Page backgrounds, sidebar backgrounds" },
      "background.tertiary": { "hex": "#f8f9fd", "semantic": "bg.neutral.subtler", "source": "Blue.50", "usage": "Guide messages, subtle fills" },
      "background.primaryHover": { "hex": "#EEEEEE", "semantic": "bg.neutral.hovered", "source": "Grey.200 approx", "usage": "Surface hover state" },
      "background.primaryPressed": { "hex": "#E0E0E0", "semantic": "bg.neutral.pressed", "source": "Grey.300", "usage": "Surface pressed/active state" },
      "background.borderless": { "hex": "transparent", "semantic": "bg.transparent", "source": "transparent", "usage": "Transparent backgrounds" },
      "foundation.assent": { "hex": "#346bea", "semantic": "bg.brand.default", "source": "Blue.500", "usage": "Brand/primary action backgrounds (contained buttons)" },
      "foundation.assentHover": { "hex": "#0260C9", "semantic": "bg.brand.hovered", "source": "System Blue (dark)", "usage": "Brand background hover" },
      "foundation.assentPressed": { "hex": "#014599", "semantic": "bg.brand.pressed", "source": "System Blue (darker)", "usage": "Brand background pressed" },
      "background.negative": { "hex": "#ffeae9", "semantic": "bg.danger.default", "source": "Red.50", "usage": "Error/danger background, error banners" },
      "foundation.negative": { "hex": "#dd1f11", "semantic": "bg.danger.bold", "source": "Red.700", "usage": "Bold danger background (destructive buttons)" },
      "foundation.negativeHover": { "hex": "#c31818", "semantic": "bg.danger.bold.hovered", "source": "Red.800", "usage": "Destructive button hover" },
      "foundation.negativePressed": { "hex": "#a11010", "semantic": "bg.danger.bold.pressed", "source": "Red.900", "usage": "Destructive button pressed" },
      "background.positive": { "hex": "#E8F5E9", "semantic": "bg.success.default", "source": "System Green light", "usage": "Success background, success banners" },
      "foundation.positive": { "hex": "#429746", "semantic": "bg.success.bold", "source": "Green.500", "usage": "Bold success background" },
      "background.warning": { "hex": "#ffebad", "semantic": "bg.warning.default", "source": "Yellow.50", "usage": "Warning background, warning banners" },
      "foundation.warning": { "hex": "#ffca28", "semantic": "bg.warning.bold", "source": "Yellow.300", "usage": "Bold warning background" },
      "background.informative": { "hex": "#E1F5FE", "semantic": "bg.information.default", "source": "System Blue light", "usage": "Info background, info banners" },
      "foundation.informative": { "hex": "#0288D1", "semantic": "bg.information.bold", "source": "System Blue", "usage": "Bold info background" },
      "background.disabled": { "hex": "#F5F5F5", "semantic": "bg.disabled", "source": "Grey.100 approx", "usage": "Disabled element backgrounds" },
      "background.selected": { "hex": "#E3F2FD", "semantic": "bg.selected.default", "source": "System Blue very light", "usage": "Selected item background" },
      "background.selectedHover": { "hex": "#BBDEFB", "semantic": "bg.selected.hovered", "source": "Blue.200", "usage": "Selected item hover state" },
      "background.input": { "hex": "#FFFFFF", "semantic": "bg.input.default", "source": "White", "usage": "Form input backgrounds" },
      "background.inputHover": { "hex": "#FAFAFA", "semantic": "bg.input.hovered", "source": "Grey.50 approx", "usage": "Form input hover" },
      "background.inputDisabled": { "hex": "#F5F5F5", "semantic": "bg.input.disabled", "source": "Grey.100 approx", "usage": "Disabled form input" },
      "background.info": { "hex": "#ebf0fd", "semantic": "bg.information.subtle", "source": "Blue.100", "usage": "Subtle info background, tooltips" }
    },

    "border": {
      "border.primary": { "hex": "#ececec", "semantic": "border.neutral.default", "source": "Grey.100", "usage": "Standard borders, dividers, panel borders" },
      "border.secondary": { "hex": "#ebf0fd", "semantic": "border.neutral.subtle", "source": "Blue.100", "usage": "Subtle borders, section separators" },
      "border.beta": { "hex": "#346bea", "semantic": "border.beta", "source": "Blue.500", "usage": "Beta feature borders" },
      "border.black": { "hex": "#000000", "semantic": "border.black", "source": "Black", "usage": "Pure black borders" },
      "border.warning": { "hex": "#ffdd74", "semantic": "border.warning.subtle", "source": "Yellow.100", "usage": "Warning container borders" },
