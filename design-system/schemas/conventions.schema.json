{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "conventions.schema.json",
  "title": "MSM Portal Conventions",
  "description": "Schema for design-system/src/conventions.json",
  "type": "object",
  "required": ["meta", "namingPrefixes", "fileNaming", "importAliases"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string" }
      }
    },
    "namingPrefixes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["prefix", "type", "description", "examples"],
        "properties": {
          "prefix": {
            "type": "string",
            "description": "Prefix string (e.g. MC, MT, SC, ME, use)",
            "minLength": 1
          },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "examples": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "fileNaming": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["pattern", "useCase", "examples"],
        "properties": {
          "pattern": { "type": "string" },
          "useCase": { "type": "string" },
          "examples": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "importAliases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["alias", "resolves"],
        "properties": {
          "alias": {
            "type": "string",
            "description": "Import alias starting with @msm-portal/",
            "pattern": "^@msm-portal/"
          },
          "resolves": { "type": "string" }
        }
      }
    },
    "importOrder": {
      "type": "array",
      "items": { "type": "string" }
    },
    "styledComponentRules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "formComponentRules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "directoryStructure": {
      "type": "object",
      "properties": {
        "componentPattern": { "type": "string" },
        "formPattern": { "type": "string" },
        "appPattern": { "type": "string" }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["description", "layers"],
      "properties": {
        "description": { "type": "string" },
        "layers": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["name", "location", "responsibility"],
            "properties": {
              "name": { "type": "string" },
              "location": { "type": "string" },
              "naming": { "type": "string" },
              "responsibility": { "type": "string" }
            }
          }
        }
      }
    },
    "containerNaming": {
      "type": "object",
      "required": ["pattern", "actions", "examples"],
      "properties": {
        "pattern": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "examples": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "buildCommands": { "type": "object" },
    "envVars": {
      "type": "object",
      "properties": {
        "prefix": { "type": "string" },
        "access": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "note": { "type": "string" }
      }
    },
    "clients": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
