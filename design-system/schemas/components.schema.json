{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "components.schema.json",
  "title": "MSM Portal Component Library",
  "description": "Schema for design-system/src/components.json",
  "type": "object",
  "required": ["meta", "categories"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["description", "basePath", "importAlias"],
      "properties": {
        "description": { "type": "string" },
        "basePath": { "type": "string" },
        "importAlias": { "type": "string" }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "components"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "components": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/component" }
          }
        }
      }
    }
  },
  "$defs": {
    "prop": {
      "type": "object",
      "required": ["name", "type", "required", "description"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "default": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "component": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Component or shared styled primitive name",
          "pattern": "^((MC|SC)[A-Z]|EmptyState$)"
        },
        "path": { "type": "string" },
        "description": { "type": "string" },
        "formikRequired": { "type": "boolean" },
        "props": {
          "type": "array",
          "items": { "$ref": "#/$defs/prop" }
        },
        "states": {
          "type": "array",
          "items": { "$ref": "#/$defs/state" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dos": {
          "type": "array",
          "items": { "type": "string" }
        },
        "donts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "example": { "type": "string" }
      }
    }
  }
}
