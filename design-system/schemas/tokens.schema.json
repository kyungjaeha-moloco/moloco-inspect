{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tokens.schema.json",
  "title": "MSM Portal Design Tokens",
  "description": "Schema for design-system/src/tokens.json",
  "type": "object",
  "required": ["meta", "color", "colorPalette", "elevation", "spacing", "typography"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["description", "source", "themeAccessPattern", "version"],
      "properties": {
        "description": { "type": "string" },
        "source": { "type": "string" },
        "themeProvider": { "type": "string" },
        "themeAccessPattern": { "type": "string" },
        "version": { "type": "string" },
        "lastUpdated": { "type": "string" }
      }
    },
    "color": {
      "type": "object",
      "required": ["description", "text", "background", "border", "icon"],
      "properties": {
        "description": { "type": "string" },
        "naming": { "type": "string" },
        "properties": { "type": "array", "items": { "type": "string" } },
        "roles": { "type": "array", "items": { "type": "string" } },
        "text": { "$ref": "#/$defs/colorCategory" },
        "background": { "$ref": "#/$defs/colorCategory" },
        "border": { "$ref": "#/$defs/colorCategory" },
        "icon": { "$ref": "#/$defs/colorCategory" }
      }
    },
    "colorPalette": {
      "type": "object",
      "required": ["description", "families"],
      "properties": {
        "description": { "type": "string" },
        "families": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "swatches"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "swatches": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "hex"],
                  "properties": {
                    "name": { "type": "string" },
                    "hex": { "type": "string" },
                    "primary": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "elevation": {
      "type": "object",
      "required": ["description", "levels"],
      "properties": {
        "description": { "type": "string" },
        "usage": { "type": "string" },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "surface", "shadow", "usage"],
            "properties": {
              "name": { "type": "string" },
              "surface": { "type": "string" },
              "shadow": { "type": "string" },
              "usage": { "type": "string" },
              "zIndex": { "type": "number" }
            }
          }
        }
      }
    },
    "spacing": {
      "type": "object",
      "required": ["description", "usage", "baseUnit", "values"],
      "properties": {
        "description": { "type": "string" },
        "usage": { "type": "string" },
        "multiArgument": { "type": "string" },
        "baseUnit": { "type": "number" },
        "values": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["multiplier", "px", "usage"],
            "properties": {
              "multiplier": { "type": "number" },
              "px": { "type": "number" },
              "usage": { "type": "string" },
              "category": { "type": "string" }
            }
          }
        },
        "categories": { "type": "object" }
      }
    },
    "typography": {
      "type": "object",
      "required": ["description", "usage", "tokens"],
      "properties": {
        "description": { "type": "string" },
        "usage": { "type": "string" },
        "tokens": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "token", "size", "weight", "lineHeight", "usage"],
            "properties": {
              "name": { "type": "string" },
              "token": { "type": "string" },
              "size": { "type": "string", "pattern": "^[0-9]+px$" },
              "weight": { "type": "string", "pattern": "^[0-9]+$" },
              "lineHeight": {
                "anyOf": [
                  { "type": "string", "pattern": "^[0-9]+px$" },
                  { "type": "null" }
                ]
              },
              "usage": { "type": "string" },
              "category": { "type": "string", "enum": ["heading", "body"] }
            }
          }
        },
        "properties": { "type": "array" },
        "guidelines": { "type": "object" }
      }
    }
  },
  "$defs": {
    "colorToken": {
      "type": "object",
      "required": ["name", "token", "hex", "usage"],
      "properties": {
        "name": { "type": "string" },
        "token": { "type": "string", "pattern": "^theme\\.mcui\\." },
        "hex": { "type": "string" },
        "usage": { "type": "string" },
        "role": { "type": "string" },
        "state": { "type": "string" }
      }
    },
    "colorCategory": {
      "type": "object",
      "required": ["description", "tokens"],
      "properties": {
        "description": { "type": "string" },
        "tokens": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/colorToken" }
        }
      }
    }
  }
}
