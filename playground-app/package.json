{
  "name": "moloco-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "trap 'kill 0' EXIT INT TERM; lsof -ti :4180 | xargs kill -9 2>/dev/null; vite --host 0.0.0.0 --port 4180",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4181",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.7.2",
    "vite": "^5.4.10",
    "vitest": "^3.0.0"
  }
}
