{
  "name": "msm-portal-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9"
  },
  "scripts": {
    "start": "pnpm vite --mode ${MODE}",
    "start:msm-default:test": "MODE=test CLIENT=msm-default pnpm start",
    "start:tving:test": "MODE=test CLIENT=tving pnpm start",
    "start:tving:staging": "MODE=staging CLIENT=tving pnpm start",
    "start:shortmax:test": "MODE=test CLIENT=shortmax pnpm start",
    "start:onboard-demo:test": "MODE=test CLIENT=onboard-demo pnpm start",
    "cypress:open": "pnpm exec cypress open --config-file cypress.config.mts",
    "build": "tsc -b && vite build --mode ${MODE}",
    "build:msm-default:test": "MODE=test CLIENT=msm-default pnpm build",
    "build:tving:test": "MODE=test CLIENT=tving pnpm build",
    "build:shortmax:test": "MODE=test CLIENT=shortmax pnpm build",
    "build:onboard-demo:test": "MODE=test CLIENT=onboard-demo pnpm build",
    "manual-deploy:tving:test": "pnpm install && pnpm build:tving:test && pnpm pnpm firebase -P test deploy --only hosting:tving",
    "manual-deploy:msm-default:test": "pnpm install && pnpm build:msm-default:test && pnpm pnpm firebase -P test deploy --only hosting:msm-default",
    "manual-deploy:shortmax:test": "pnpm install && pnpm build:shortmax:test && pnpm pnpm firebase -P test deploy --only hosting:shortmax",
    "manual-deploy:onboard-demo:test": "pnpm install && pnpm build:onboard-demo:test && pnpm pnpm firebase -P test deploy --only hosting:onboard-demo",
    "lint": "eslint .",
    "prettier": "prettier --write '**/*.{ts,tsx,js,jsx,css,html}'",
    "preview": "vite preview",
    "prepare": "cd ../../ && husky js/msm-portal-web/.husky",
    "validate-import": "tsx script/validation/import-statement/index",
    "client-app": "tsx script/client-app/index"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md,html}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@datadog/browser-rum": "5.35.0",
    "@moloco/moloco-cloud-react-hooks": "0.0.2",
    "@moloco/moloco-cloud-react-ui": "0.0.123",
    "@tanstack/react-query": "5.59.16",
    "@trpc/client": "11.3.1",
    "@trpc/server": "11.3.1",
    "@trpc/tanstack-react-query": "11.3.1",
    "axios": "1.7.7",
    "csv-parse": "5.6.0",
    "date-fns": "4.1.0",
    "dayjs": "1.11.13",
    "filesize": "10.1.6",
    "formik": "2.4.6",
    "i18next": "23.16.2",
    "i18next-browser-languagedetector": "8.0.2",
    "lodash-es": "4.17.21",
    "mediainfo.js": "0.3.3",
    "nanoid": "5.0.9",
    "notistack": "3.0.1",
    "numeral": "2.0.6",
    "papaparse": "5.5.3",
    "qrcode.react": "4.2.0",
    "react": "18.3.1",
    "react-color": "2.19.3",
    "react-dom": "18.3.1",
    "react-i18next": "15.1.0",
    "react-idle-timer": "5.7.2",
    "react-router-dom": "6.27.0",
    "react-router-hash-link": "2.4.3",
    "react-virtualized-auto-sizer": "1.0.26",
    "react-window": "1.8.10",
    "styled-components": "6.1.13",
    "yup": "1.4.0",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^6.0.2",
    "@eslint/js": "9.11.1",
    "@tanstack/react-query-devtools": "5.62.16",
    "@types/lodash-es": "4.17.12",
    "@types/node": "22.7.6",
    "@types/numeral": "2.0.2",
    "@types/papaparse": "5.3.16",
    "@types/react": "18.3.10",
    "@types/react-color": "3.0.13",
    "@types/react-dom": "18.3.0",
    "@types/react-router-hash-link": "2.4.9",
    "@types/react-window": "1.8.8",
    "@types/styled-components": "5.1.34",
    "@typescript-eslint/eslint-plugin": "8.9.0",
    "@typescript-eslint/parser": "8.9.0",
    "@vitejs/plugin-react": "4.3.2",
    "commander": "13.1.0",
    "cypress": "^14.3.1",
    "eslint": "9.11.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.3",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.0",
    "eslint-plugin-react": "7.37.1",
    "eslint-plugin-react-hooks": "5.1.0-rc.0",
    "eslint-plugin-react-refresh": "0.4.12",
    "globals": "15.9.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "rollup-plugin-visualizer": "5.12.0",
    "serve": "^14.2.4",
    "ts-loader": "^9.5.2",
    "tsx": "4.19.2",
    "typescript": "5.5.3",
    "typescript-eslint": "8.7.0",
    "vite": "5.4.8",
    "vite-plugin-i18next-loader": "2.0.14",
    "vite-plugin-node-polyfills": "0.22.0",
    "vite-plugin-svgr": "4.2.0",
    "yaml": "2.7.0",
    "zod": "3.24.1"
  }
}
