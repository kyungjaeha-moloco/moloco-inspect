{
  "manifest_version": 3,
  "name": "Moloco Inspect",
  "description": "Select UI elements visually and send edit requests to a sandbox agent",
  "version": "1.1.0",
  "permissions": ["activeTab", "tabs", "nativeMessaging", "storage", "sidePanel", "scripting", "alarms"],
  "content_scripts": [
    {
      "matches": ["http://localhost:*/*", "http://127.0.0.1:*/*"],
      "js": ["content-script.js"],
      "css": ["content-style.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
