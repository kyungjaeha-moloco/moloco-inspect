flowchart TD
    REQ["Request Received"]
    ANALYSIS["AI Analysis\nClaude Sonnet · ~3s"]
    SANDBOX["Create Sandbox · 2-5s"]
    SYNC["Sync Source · 3-8s"]
    AGENT["Run Agent · 30-120s"]
    DIFF["Collect Diff"]
    DONE_NC["No Change Needed"]
    TC["TypeScript Check · 5-30s"]
    PREVIEW["Start Vite Preview · 30-90s"]
    SS["Playwright Screenshot"]
    READY["Preview Ready"]
    PR["Create GitHub PR"]

    REQ --> ANALYSIS
    ANALYSIS -->|"PM Confirms"| SANDBOX
    SANDBOX --> SYNC
    SYNC --> AGENT
    AGENT --> DIFF
    DIFF -->|"No changes"| DONE_NC
    DIFF -->|"Has changes"| TC
    TC --> PREVIEW
    PREVIEW --> SS
    SS --> READY
    READY -->|"Approve"| PR
    READY -->|"Reject + Feedback"| AGENT

    style REQ fill:#e8eaed,stroke:#5f6368,color:#202124
    style ANALYSIS fill:#e8f0fe,stroke:#1a73e8,color:#1a73e8
    style SANDBOX fill:#fef7e0,stroke:#f9ab00,color:#e37400
    style SYNC fill:#fef7e0,stroke:#f9ab00,color:#e37400
    style AGENT fill:#1a73e8,stroke:#1557b0,color:#ffffff
    style DIFF fill:#f8f9fa,stroke:#5f6368,color:#202124
    style TC fill:#e6f4ea,stroke:#34a853,color:#137333
    style PREVIEW fill:#e6f4ea,stroke:#34a853,color:#137333
    style SS fill:#e6f4ea,stroke:#34a853,color:#137333
    style READY fill:#34a853,stroke:#1e8e3e,color:#ffffff
    style PR fill:#34a853,stroke:#1e8e3e,color:#ffffff
    style DONE_NC fill:#e8eaed,stroke:#5f6368,color:#5f6368
