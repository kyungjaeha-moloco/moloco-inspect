%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#0f62fe', 'primaryTextColor': '#fff', 'lineColor': '#525252', 'fontSize': '13px' }}}%%
flowchart TD
    REQ["Request Received"] --> ANALYSIS["AI Analysis — Claude Sonnet ~3s"]
    ANALYSIS --> |PM Confirms| SANDBOX["Create Sandbox 2-5s"]
    SANDBOX --> SYNC["Sync Source 3-8s"]
    SYNC --> AGENT["Run Agent 30-120s"]
    AGENT --> DIFF["Collect Diff"]
    DIFF --> |No changes| DONE_NC["No Change Needed"]
    DIFF --> |Has changes| TC["TypeScript Check 5-30s"]
    TC --> PREVIEW["Start Vite Preview 30-90s"]
    PREVIEW --> SS["Playwright Screenshot"]
    SS --> READY["Preview Ready"]
    READY --> |Approve| PR["Create GitHub PR"]
    READY --> |Reject + Feedback| AGENT

    style REQ fill:#e0e0e0,stroke:#525252
    style ANALYSIS fill:#d4e5ff,stroke:#0f62fe
    style SANDBOX fill:#fff3e0,stroke:#f57c00
    style SYNC fill:#fff3e0,stroke:#f57c00
    style AGENT fill:#0f62fe,stroke:#0043ce,color:#fff
    style DIFF fill:#f4f4f4,stroke:#525252
    style TC fill:#e8f5e9,stroke:#24a148
    style PREVIEW fill:#e8f5e9,stroke:#24a148
    style SS fill:#e8f5e9,stroke:#24a148
    style READY fill:#24a148,stroke:#198038,color:#fff
    style PR fill:#24a148,stroke:#198038,color:#fff
    style DONE_NC fill:#e0e0e0,stroke:#8d8d8d
