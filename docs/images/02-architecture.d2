direction: down

# ─── Entry Points ───
chrome: "Chrome Extension" {
  style: {
    fill: "#1a73e8"
    stroke: "#1557b0"
    font-color: "#ffffff"
    border-radius: 10
    font-size: 16
    bold: true
  }
}
slack: "Slack Bot (Next)" {
  style: {
    fill: "#dadce0"
    stroke: "#9aa0a6"
    font-color: "#5f6368"
    border-radius: 10
    font-size: 14
  }
}
jira: "Jira (Planned)" {
  style: {
    fill: "#dadce0"
    stroke: "#9aa0a6"
    font-color: "#5f6368"
    border-radius: 10
    font-size: 14
  }
}

# ─── Orchestrator ───
orchestrator: "Orchestrator" {
  style: {
    fill: "#f8f9fa"
    stroke: "#5f6368"
    border-radius: 12
    font-size: 15
    bold: true
  }

  analysis: "AI Analysis\nClaude Sonnet 4.6" {
    style: { fill: "#e8f0fe"; stroke: "#1a73e8"; border-radius: 8; font-size: 14 }
  }
  pipeline: "Pipeline Engine\n11 API Endpoints" {
    style: { fill: "#e8f0fe"; stroke: "#1a73e8"; border-radius: 8; font-size: 14 }
  }
  pr: "PR Creation\ngh pr create" {
    style: { fill: "#e8f0fe"; stroke: "#1a73e8"; border-radius: 8; font-size: 14 }
  }

  analysis -> pipeline -> pr
}

# ─── Sandbox ───
sandbox: "Docker Sandbox" {
  style: {
    fill: "#fef7e0"
    stroke: "#f9ab00"
    border-radius: 12
    font-size: 15
    bold: true
  }

  agent: "AI Agent\nCode Modification" {
    style: { fill: "#1a73e8"; stroke: "#1557b0"; font-color: "#ffffff"; border-radius: 8; font-size: 14; bold: true }
  }
  typecheck: "TypeScript\nCheck" {
    style: { fill: "#ffffff"; stroke: "#f9ab00"; border-radius: 8; font-size: 13 }
  }
  preview: "Vite\nLive Preview" {
    style: { fill: "#ffffff"; stroke: "#f9ab00"; border-radius: 8; font-size: 13 }
  }
  screenshot: "Playwright\nScreenshot" {
    style: { fill: "#ffffff"; stroke: "#f9ab00"; border-radius: 8; font-size: 13 }
  }

  agent -> typecheck -> preview -> screenshot
}

# ─── Data Layer ───
ops: "Inspect Hub\nDashboard · Metrics\nDiff Review · Timeline" {
  style: {
    fill: "#34a853"
    stroke: "#1e8e3e"
    font-color: "#ffffff"
    border-radius: 10
    font-size: 14
    bold: true
  }
}
ds: "Design System\n95 Components\n186 Tokens · Doc Site" {
  style: {
    fill: "#1a73e8"
    stroke: "#1557b0"
    font-color: "#ffffff"
    border-radius: 10
    font-size: 14
    bold: true
  }
}
mcp: "MCP Server\n9 AI Tools" {
  style: {
    fill: "#1a73e8"
    stroke: "#1557b0"
    font-color: "#ffffff"
    border-radius: 10
    font-size: 14
    bold: true
  }
}

# ─── Connections ───
chrome -> orchestrator: "HTTP" {
  style: { stroke: "#1a73e8"; font-size: 12 }
}
slack -> orchestrator: {
  style: { stroke-dash: 5; stroke: "#9aa0a6" }
}
jira -> orchestrator: {
  style: { stroke-dash: 5; stroke: "#9aa0a6" }
}
orchestrator -> sandbox: "Docker API" {
  style: { stroke: "#f9ab00"; font-size: 12 }
}
ds -> sandbox.agent: "Context" {
  style: { stroke: "#1a73e8"; font-size: 12; stroke-dash: 3 }
}
orchestrator -> ops: "Events" {
  style: { stroke: "#34a853"; font-size: 12 }
}
