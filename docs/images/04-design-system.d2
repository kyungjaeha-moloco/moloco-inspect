direction: down

# ─── Source of Truth ───
source: "Source of Truth" {
  style: {
    fill: "#e8f0fe"
    stroke: "#1a73e8"
    border-radius: 12
    font-size: 15
    bold: true
  }

  components: "95 Component Contracts\nProps · Variants · States · Tokens · Anti-patterns" {
    style: { fill: "#1a73e8"; stroke: "#1557b0"; font-color: "#ffffff"; border-radius: 8; font-size: 14; bold: true }
  }
  tokens: "186 Design Tokens\nSemantic Palette · Spacing · Radius · Shadow" {
    style: { fill: "#1a73e8"; stroke: "#1557b0"; font-color: "#ffffff"; border-radius: 8; font-size: 14; bold: true }
  }
  patterns: "12 UI Patterns\nForm · Table · Dashboard · Dialog · List · Detail" {
    style: { fill: "#1a73e8"; stroke: "#1557b0"; font-color: "#ffffff"; border-radius: 8; font-size: 14; bold: true }
  }
}

# ─── Main consumer ───
agent: "AI Agent\nReads contracts + tokens to generate correct code" {
  style: { fill: "#34a853"; stroke: "#1e8e3e"; font-color: "#ffffff"; border-radius: 10; font-size: 15; bold: true }
}

# ─── Other consumers ───
consumers: "Other Consumers" {
  style: {
    fill: "#e6f4ea"
    stroke: "#34a853"
    border-radius: 12
    font-size: 14
    bold: true
  }

  doc_site: "Documentation Site\nInteractive previews · Prop controls\nAnatomy diagrams · Search" {
    style: { fill: "#ffffff"; stroke: "#34a853"; border-radius: 8; font-size: 13 }
  }
  mcp: "MCP Server — 9 Tools\nAI tools query components, tokens, patterns" {
    style: { fill: "#ffffff"; stroke: "#34a853"; border-radius: 8; font-size: 13 }
  }
  llms: "llms.txt\nAI-readable component index" {
    style: { fill: "#ffffff"; stroke: "#34a853"; border-radius: 8; font-size: 13 }
  }
}

# ─── Quality ───
quality: "Quality Checks" {
  style: {
    fill: "#fef7e0"
    stroke: "#f9ab00"
    border-radius: 12
    font-size: 14
    bold: true
  }

  typecheck: "TypeScript Check" {
    style: { fill: "#ffffff"; stroke: "#f9ab00"; border-radius: 8; font-size: 13 }
  }
  evaluator: "Evaluator Agent (Phase 2)" {
    style: { fill: "#ffffff"; stroke: "#f9ab00"; border-radius: 8; font-size: 13 }
  }
  drift: "Drift Detection (Phase 3)" {
    style: { fill: "#ffffff"; stroke: "#f9ab00"; border-radius: 8; font-size: 13 }
  }

  typecheck -> evaluator: { style.stroke-dash: 5 }
  evaluator -> drift: { style.stroke-dash: 5 }
}

# ─── Connections ───
source -> agent: "references" { style.font-size: 12 }
source -> consumers: { style.stroke: "#34a853" }
agent -> quality: "generated code" { style.font-size: 12 }
