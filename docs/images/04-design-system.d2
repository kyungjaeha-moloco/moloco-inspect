direction: down

title: "Design System Data Flow" {
  style: {
    font-size: 20
    bold: true
    fill: "#ffffff"
    stroke: "#ffffff"
  }
}

# ─── Source of Truth (center, top) ───
components: "95 Component Contracts\nProps · Variants · States · Tokens · Anti-patterns" {
  style: { fill: "#1a73e8"; stroke: "#1557b0"; font-color: "#ffffff"; border-radius: 10; font-size: 15; bold: true }
}
tokens: "186 Design Tokens\nSemantic Palette · Spacing · Radius · Shadow" {
  style: { fill: "#1a73e8"; stroke: "#1557b0"; font-color: "#ffffff"; border-radius: 10; font-size: 15; bold: true }
}
patterns: "12 UI Patterns\nForm · Table · Dashboard · Dialog · List · Detail" {
  style: { fill: "#1a73e8"; stroke: "#1557b0"; font-color: "#ffffff"; border-radius: 10; font-size: 15; bold: true }
}

# ─── How it's consumed ───
agent: "AI Agent\nReads contracts + tokens\nto generate correct code" {
  shape: rectangle
  style: { fill: "#34a853"; stroke: "#1e8e3e"; font-color: "#ffffff"; border-radius: 10; font-size: 15; bold: true }
}

doc_site: "Documentation Site\nInteractive previews · Prop controls\nAnatomy diagrams · Dark mode · Search" {
  style: { fill: "#e6f4ea"; stroke: "#34a853"; border-radius: 10; font-size: 14 }
}

mcp_server: "MCP Server — 9 Tools\nAny AI tool can query\ncomponents, tokens, patterns" {
  style: { fill: "#e6f4ea"; stroke: "#34a853"; border-radius: 10; font-size: 14 }
}

llms_txt: "llms.txt\nAI-readable index\nfor LLM integrations" {
  style: { fill: "#e6f4ea"; stroke: "#34a853"; border-radius: 10; font-size: 14 }
}

# ─── Quality checks ───
typecheck: "TypeScript Check\nType safety on generated code" {
  style: { fill: "#fef7e0"; stroke: "#f9ab00"; border-radius: 10; font-size: 14 }
}
evaluator: "Evaluator Agent (Phase 2)\nAuto-score DS compliance" {
  style: { fill: "#fef7e0"; stroke: "#f9ab00"; border-radius: 10; font-size: 14 }
}
drift: "Drift Detection (Phase 3)\nCI blocks hardcoded values" {
  style: { fill: "#fef7e0"; stroke: "#f9ab00"; border-radius: 10; font-size: 14 }
}

# ─── Main flow (center) ───
components -> agent: "references" { style.font-size: 12 }
tokens -> agent: "uses" { style.font-size: 12 }
patterns -> agent: "follows" { style.font-size: 12 }

agent -> typecheck: "generated code" { style.font-size: 12 }
typecheck -> evaluator: { style.stroke-dash: 5 }
evaluator -> drift: { style.stroke-dash: 5 }

# ─── Side consumers ───
components -> doc_site: { style.stroke: "#34a853" }
components -> mcp_server: { style.stroke: "#34a853" }
components -> llms_txt: { style.stroke: "#34a853" }
